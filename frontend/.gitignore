# ==========================================
# Frontend .gitignore - Next.js / React
# ==========================================

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/
/.turbo/

# Production
/build

# Misc
.DS_Store
*.pem
*.tmp
*.temp

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment variables (NEVER COMMIT!)
.env*
!.env.example

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# ==========================================
# IDE / Editor
# ==========================================
.vscode/
.idea/
*.code-workspace
*.swp
*.swo

# OS Files
Thumbs.db
desktop.ini

# ==========================================
# Debug / Temp Scripts
# ==========================================
*.cjs
*.mjs
fixCurrency.cjs
updateUI*.cjs
updatePayrollConfigPanel.js

# ==========================================
# Documentation (Optional)
# ==========================================
# Uncomment if you don't want to commit implementation docs
# *.md
# !README.md
# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

